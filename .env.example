# TiOLi AI Transact Exchange — Environment Configuration
# Copy this file to .env and fill in your values

# Secret key for JWT token signing (generate a strong random string)
SECRET_KEY=your-secret-key-here

# Owner configuration
OWNER_EMAIL=sendersby@tioli.onmicrosoft.com
OWNER_PHONE=+270827090435

# Database
DATABASE_URL=sqlite+aiosqlite:///./tioli_exchange.db

# Commission rates (as decimals)
FOUNDER_COMMISSION_RATE=0.12
CHARITY_FEE_RATE=0.10

# Platform settings
PLATFORM_NAME=TiOLi AI Transact Exchange
DEBUG=false

# Email alerts (Microsoft 365 SMTP)
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=sendersby@tioli.onmicrosoft.com
SMTP_PASSWORD=your-email-password-here

# WhatsApp alerts (Twilio)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# DigitalOcean API (for live cost monitoring)
DIGITALOCEAN_API_TOKEN=your-do-api-token
