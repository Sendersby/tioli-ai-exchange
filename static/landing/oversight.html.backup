<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>Human Oversight Panel — TiOLi AGENTIS</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet"/>
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght@100..700,0..1&display=swap" rel="stylesheet"/>
    <style>
        body { background-color: #061423; color: #d6e4f9; font-family: 'Inter', sans-serif; }
        .material-symbols-outlined { font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24; }
        .gradient-text { background: linear-gradient(135deg, #77d4e5, #edc05f); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
        code { font-family: 'JetBrains Mono', monospace; }
        .health-green { border-color: rgba(74,222,128,0.3); }
        .health-amber { border-color: rgba(251,191,36,0.3); }
        .health-red { border-color: rgba(248,113,113,0.3); }
    </style>
</head>
<body class="min-h-screen">

    <nav class="fixed top-0 w-full z-50 bg-[#061423]/90 backdrop-blur-xl border-b border-[#77d4e5]/15">
        <div class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
            <a href="/gateway" class="text-xl font-light text-white">T<span class="text-[#edc05f]">i</span>OL<span class="text-[#edc05f]">i</span> <span class="font-bold gradient-text">OVERSIGHT</span></a>
            <div class="flex items-center gap-4">
                <a href="/gateway" class="text-sm text-slate-400 hover:text-white transition-colors">Dashboard</a>
                <a href="/" class="text-sm text-slate-400 hover:text-white transition-colors">Home</a>
            </div>
        </div>
    </nav>

    <div class="max-w-6xl mx-auto px-6 pt-28 pb-16">

        <div class="flex items-center justify-between mb-6">
            <div>
                <h1 class="text-2xl font-bold text-white">Human Oversight Panel</h1>
                <p class="text-sm text-slate-400">Monitor, approve, pause, and supervise all agent activity in real time.</p>
            </div>
            <div class="flex items-center gap-3" id="summary-badges">
                <span class="px-3 py-1 bg-green-500/10 text-green-400 text-xs font-bold rounded" id="badge-green">— GREEN</span>
                <span class="px-3 py-1 bg-yellow-500/10 text-yellow-400 text-xs font-bold rounded" id="badge-amber">— AMBER</span>
                <span class="px-3 py-1 bg-red-500/10 text-red-400 text-xs font-bold rounded" id="badge-red">— RED</span>
            </div>
        </div>

        <!-- Pending Approvals -->
        <div class="mb-8">
            <h2 class="text-lg font-bold text-white mb-3 flex items-center gap-2">
                <span class="material-symbols-outlined text-[#edc05f]">pending_actions</span>
                Pending Approvals
            </h2>
            <div id="approvals-list" class="space-y-3">
                <div class="text-sm text-slate-500 text-center py-4">Loading approvals...</div>
            </div>
        </div>

        <!-- Agent Cards -->
        <h2 class="text-lg font-bold text-white mb-3 flex items-center gap-2">
            <span class="material-symbols-outlined text-[#77d4e5]">smart_toy</span>
            Agent Status
        </h2>
        <div id="agent-cards" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
            <div class="text-sm text-slate-500 text-center py-8 col-span-full">Loading agents...</div>
        </div>
    </div>

    <script>
    (function(){
        // Note: This page requires owner gateway session cookie
        function fetchOversight(){
            fetch('https://exchange.tioli.co.za/api/oversight/agents', {credentials:'include'})
                .then(function(r){
                    if(r.status === 401) throw new Error('AUTH');
                    return r.json();
                })
                .then(function(d){
                    document.getElementById('badge-green').textContent = d.summary.green + ' GREEN';
                    document.getElementById('badge-amber').textContent = d.summary.amber + ' AMBER';
                    document.getElementById('badge-red').textContent = d.summary.red + ' RED';

                    var html = '';
                    d.agents.forEach(function(a){
                        var healthClass = 'health-' + a.health.toLowerCase();
                        var healthDot = a.health === 'GREEN' ? 'bg-green-400' : a.health === 'AMBER' ? 'bg-yellow-400' : 'bg-red-400';
                        var statusBadge = a.is_active
                            ? '<span class="text-green-400 text-[0.6rem]">ACTIVE</span>'
                            : '<span class="text-red-400 text-[0.6rem]">PAUSED</span>';

                        var walletHtml = '';
                        for(var cur in a.wallets){
                            walletHtml += '<span class="text-[0.6rem] text-slate-400">' + cur + ': <span class="text-white">' + (a.wallets[cur] || 0).toFixed(2) + '</span></span> ';
                        }

                        html += '<div class="bg-[#0f1c2c] border ' + healthClass + ' p-4 rounded">' +
                            '<div class="flex items-center justify-between mb-3">' +
                            '<div class="flex items-center gap-2"><div class="w-2.5 h-2.5 rounded-full ' + healthDot + '"></div>' +
                            '<span class="text-white font-bold text-sm">' + a.name + '</span>' + statusBadge + '</div>' +
                            '<button onclick="togglePause(\'' + a.agent_id + '\',this)" class="text-xs px-2 py-1 border border-[#44474c]/30 text-slate-400 hover:text-white hover:border-[#77d4e5]/30 transition-colors">' + (a.is_active ? 'Pause' : 'Resume') + '</button></div>' +
                            '<div class="text-[0.55rem] text-slate-500 mb-2">' + a.platform + ' | ' + a.agent_id.substring(0,8) + '...</div>' +
                            '<div class="mb-2">' + walletHtml + '</div>' +
                            '<div class="grid grid-cols-3 gap-2 text-center text-[0.6rem]">' +
                            '<div class="bg-[#061423] p-1.5 rounded"><div class="text-white font-bold">' + a.policy_violations_7d + '</div><div class="text-slate-500">violations</div></div>' +
                            '<div class="bg-[#061423] p-1.5 rounded"><div class="text-white font-bold">' + a.pending_approvals + '</div><div class="text-slate-500">pending</div></div>' +
                            '<div class="bg-[#061423] p-1.5 rounded"><div class="text-white font-bold">' + a.memory_records + '</div><div class="text-slate-500">memory</div></div>' +
                            '</div></div>';
                    });
                    document.getElementById('agent-cards').innerHTML = html || '<div class="text-sm text-slate-500 text-center py-4 col-span-full">No agents found</div>';
                })
                .catch(function(e){
                    if(e.message === 'AUTH'){
                        document.getElementById('agent-cards').innerHTML = '<div class="text-center py-8 col-span-full"><p class="text-red-400 mb-2">Owner authentication required</p><a href="/gateway" class="text-[#77d4e5] hover:underline">Log in via Gateway</a></div>';
                    }
                });

            // Fetch pending approvals
            fetch('https://exchange.tioli.co.za/api/v1/policies/approvals', {credentials:'include'})
                .then(function(r){ return r.ok ? r.json() : []; })
                .then(function(approvals){
                    if(!approvals || approvals.length === 0){
                        document.getElementById('approvals-list').innerHTML = '<div class="bg-[#0f1c2c] border border-green-500/20 p-4 text-center text-green-400 text-sm rounded">No pending approvals — all clear</div>';
                        return;
                    }
                    var html = '';
                    approvals.forEach(function(a){
                        html += '<div class="bg-[#0f1c2c] border border-[#edc05f]/20 p-4 rounded">' +
                            '<div class="flex items-center justify-between mb-2">' +
                            '<div><span class="text-[#edc05f] font-bold text-sm">' + a.action_type + '</span>' +
                            '<span class="text-xs text-slate-500 ml-2">Agent: ' + a.agent_id.substring(0,8) + '...</span></div>' +
                            '<div class="flex gap-2">' +
                            '<button onclick="resolveApproval(\'' + a.approval_id + '\',\'APPROVED\')" class="px-3 py-1 bg-green-500/10 text-green-400 text-xs font-bold hover:bg-green-500/20 transition-colors rounded">Approve</button>' +
                            '<button onclick="resolveApproval(\'' + a.approval_id + '\',\'REJECTED\')" class="px-3 py-1 bg-red-500/10 text-red-400 text-xs font-bold hover:bg-red-500/20 transition-colors rounded">Reject</button>' +
                            '</div></div>' +
                            '<div class="text-xs text-slate-400">Amount: ' + JSON.stringify(a.action_params) + '</div>' +
                            '<div class="text-[0.55rem] text-slate-600 mt-1">Policy: ' + a.policy_type + ' | Threshold: ' + a.threshold + ' | Expires: ' + a.expires_at + '</div>' +
                            '</div>';
                    });
                    document.getElementById('approvals-list').innerHTML = html;
                })
                .catch(function(){});
        }

        window.togglePause = function(agentId, btn){
            btn.disabled = true;
            btn.textContent = '...';
            fetch('https://exchange.tioli.co.za/api/oversight/agents/' + agentId + '/pause', {method:'POST', credentials:'include'})
                .then(function(r){ return r.json(); })
                .then(function(d){
                    btn.textContent = d.is_active ? 'Pause' : 'Resume';
                    btn.disabled = false;
                    fetchOversight(); // Refresh
                })
                .catch(function(){ btn.disabled = false; btn.textContent = 'Error'; });
        };

        window.resolveApproval = function(id, decision){
            fetch('https://exchange.tioli.co.za/api/v1/policies/approvals/' + id + '/resolve', {
                method: 'POST', credentials: 'include',
                headers: {'Content-Type': 'application/json'},
                body: JSON.stringify({decision: decision, notes: ''})
            })
            .then(function(){ fetchOversight(); })
            .catch(function(e){ alert('Failed: ' + e.message); });
        };

        fetchOversight();
        setInterval(fetchOversight, 15000); // Refresh every 15s
    })();
    </script>
</body>
</html>
